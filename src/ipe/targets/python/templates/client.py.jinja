from __future__ import annotations

{% for resource_path in resources.keys() %}
from {{ module_name }}.resources.{{ resource_path | replace("/", ".") }} import (
    {{ resource_path.split("/")[-1] | class_name }}Resource,
    Async{{ resource_path.split("/")[-1] | class_name }}Resource,
)
{% endfor %}
from {{ module_name }}.transport import (
    AsyncHttpxTransport,
    AsyncTransport,
    HttpxTransport,
    Transport,
)
{% if auth_schemes %}
from {{ module_name }}.auth import build_auth
{% endif %}


class {{ api_name | class_name }}Client:
    """{{ api_name }} API client.
{% if spec_description %}

    {{ spec_description | strip_html | wordwrap(68, wrapstring='\n    ') }}
{% endif %}

    Usage:
        client = {{ api_name | class_name }}Client(base_url="{{ base_url or 'https://api.example.com' }}")
{% for resource_path in resources.keys() | sort %}
        client.{{ resource_path.split("/")[-1] | field_name }}.list()
{% endfor %}
    """

    def __init__(
        self,
        base_url: str = "{{ base_url or 'https://api.example.com' }}",
        *,
{% if auth_schemes %}
{{ auth_schemes | auth_params | indent(8, first=True) }}
{% endif %}
        timeout: float = 30.0,
        transport: Transport | None = None,
    ) -> None:
        if transport is None:
{% if auth_schemes %}
            headers, params, cookies{% if auth_schemes | has_client_credentials %}, auth{% endif %} = build_auth(
{{ auth_schemes | auth_call_kwargs | indent(16, first=True) }}
            )
            transport = HttpxTransport(
                base_url,
                headers=headers,
                params=params,
                cookies=cookies,
{% if auth_schemes | has_client_credentials %}
                auth=auth,
{% endif %}
                timeout=timeout,
            )
{% else %}
            transport = HttpxTransport(base_url, timeout=timeout)
{% endif %}
        self._transport = transport

{% for resource_path in resources.keys() | sort %}
        self.{{ resource_path.split("/")[-1] | field_name }} = {{ resource_path.split("/")[-1] | class_name }}Resource(self._transport)
{% endfor %}

    def close(self) -> None:
        self._transport.close()

    def __enter__(self) -> {{ api_name | class_name }}Client:
        return self

    def __exit__(self, *args: object) -> None:
        self.close()


