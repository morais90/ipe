from __future__ import annotations

{{ operations | resource_imports(module_name) }}

from {{ module_name }}.transport import AsyncTransport, Transport

{% macro method(operation, is_async) %}
{% set path_params = operation.parameters | selectattr("location", "equalto", "path") | list %}
{% set query_params = operation.parameters | selectattr("location", "equalto", "query") | list %}
{% set has_params = path_params or query_params %}
{% set has_details = operation.description or has_params %}
{% set success = operation.responses | success_response %}
{% set body = operation.request_body %}
    @validated
{% if is_async %}
    async def {{ operation.operation_id | method_name }}(
{% else %}
    def {{ operation.operation_id | method_name }}(
{% endif %}
        self,
{% for param in path_params %}
        {{ param.name | field_name }}: {{ param | field_type }},
{% endfor %}
{% if body %}
        body: {{ body | body_type }}{% if not body.required %} | None = None{% endif %},
{% endif %}
{% for param in query_params %}
        {{ param.name | field_name }}: {{ param | field_type }} | None = {% if param.default is not none %}{{ param.default | pyval }}{% else %}None{% endif %},
{% endfor %}
    ) -> {{ success | response_type }}:
{% if operation.summary and not has_details %}
        """{{ operation.summary | strip_html }}"""
{% elif operation.summary or has_details %}
        """{{ (operation.summary or '') | strip_html }}
{% if operation.description %}

        {{ operation.description | strip_html | wordwrap(64, wrapstring='\n        ') }}
{% endif %}
{% if has_params %}

        Args:
{% for param in path_params %}
            {{ ((param.name | field_name) ~ ": " ~ ((param.description or param.name) | strip_html)) | wordwrap(56, wrapstring='\n                ') }}
{% endfor %}
{% for param in query_params %}
            {{ ((param.name | field_name) ~ ": " ~ ((param.description or param.name) | strip_html)) | wordwrap(56, wrapstring='\n                ') }}
{% endfor %}
{% endif %}
        """
{% endif %}
{% if path_params %}
        url = "{{ operation.path }}".format(
{% for param in path_params %}
            {{ param.name }}={{ param.name | field_name }},
{% endfor %}
        )
{% else %}
        url = "{{ operation.path }}"
{% endif %}
        response = {% if is_async %}await {% endif %}self._transport.request(
            "{{ operation.method }}",
            url,
{% if query_params %}
            params={
{% for param in query_params %}
                "{{ param.name }}": {{ param.name | field_name }},
{% endfor %}
            },
{% endif %}
{% if body %}
            {{ body | body_call_arg }},
{% endif %}
        )
        response.raise_for_status()
        return {{ success | response_deserialize }}
{% endmacro %}


class {{ item_name | class_name }}Resource:
    def __init__(self, transport: Transport) -> None:
        self._transport = transport

{% for operation in operations %}
{{ method(operation, false) }}
{% endfor %}


class Async{{ item_name | class_name }}Resource:
    def __init__(self, transport: AsyncTransport) -> None:
        self._transport = transport

{% for operation in operations %}
{{ method(operation, true) }}
{% endfor %}
